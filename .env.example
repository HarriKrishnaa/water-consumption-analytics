# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# IoT Core Configuration
AWS_IOT_ENDPOINT=xxxxxxxxx-ats.iot.us-east-1.amazonaws.com
AWS_IOT_POLICY_NAME=water-meter-policy
AWS_IOT_THING_NAME=water-meter-device-001

# Kinesis Configuration
KINESIS_STREAM_NAME=water-meter-readings-stream
KINESIS_REGION=us-east-1

# Timestream Configuration
TIMESTREAM_DATABASE_NAME=water-meter-analytics
TIMESTREAM_TABLE_NAME=water_meter_readings

# DynamoDB Configuration
DYNAMODB_ALERTS_TABLE=flat-consumption-alerts
DYNAMODB_REGION=us-east-1

# S3 Configuration
S3_BUCKET_NAME=water-meter-analytics-4626
S3_REGION=us-east-1

# SES Configuration
SES_SENDER_EMAIL=alerts@water-analytics.com
SES_REGION=us-east-1

# Application Configuration
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://your-vercel-domain.vercel.app
LOG_LEVEL=info

# Leak Detection Settings
LEAK_THRESHOLD_MULTIPLIER=3
NIGHTTIME_LEAK_THRESHOLD=50
NIGHTTIME_WINDOW_START=2
NIGHTTIME_WINDOW_END=4
